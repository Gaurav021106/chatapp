<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script src="https://cdn.tailwindcss.com"></script>
    <title>Edit Profile | ChatApp</title>

    <style>
        .animate-fadeIn { animation: fadeIn 1s ease-out; }
        .animate-slideUp { animation: slideUp 0.7s ease-out; }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .animated-item {
            opacity: 0;
            animation-fill-mode: both;
        }
    </style>
</head>

<body class="bg-[#5E6572] min-h-screen flex items-center justify-center p-4 m-0 font-sans">
    <div class="w-full max-w-2xl bg-[#7D98A1] rounded-3xl p-8 shadow-2xl animate-fadeIn">
        <h1 class="text-3xl font-bold mb-7 text-center text-white">Edit Profile</h1>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="bg-red-100 border border-red-400 text-red-700 p-4 rounded-xl mb-6 font-semibold shadow-sm text-center animated-item" style="animation-delay: 0.1s; animation: slideUp 0.5s ease-out 0.1s forwards;">
                <%= error %>
            </div>
        <% } %>

        <form action="/edit_profile" method="POST" enctype="multipart/form-data" class="space-y-6">
            
            <div class="flex gap-4 items-center justify-center animated-item" style="animation-delay: 0.2s; animation: slideUp 0.5s ease-out 0.2s forwards;">
                <div class="relative group transform hover:scale-[1.02] transition-transform duration-300">
                    <div class="w-40 h-40 rounded-full bg-white overflow-hidden shadow-lg ring-4 ring-white/50">
                        <img id="profilePreview"
                            src="<%= user.profile_picture ? user.profile_picture.replace('./', '/') : '/images/required/profile.jpeg' %>"
                            alt="profile" class="object-cover w-full h-full" />
                    </div>
                    <div class="absolute inset-0 flex items-center justify-center bg-black/40 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300 cursor-pointer" onclick="document.getElementById('profileImage').click()">
                        <div class="bg-black/60 text-white p-3 rounded-full shadow-xl">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                        </div>
                    </div>
                    <input type="file" id="profileImage" name="profileImage" accept="image/*" class="hidden" />
                </div>
            </div>

            <div class="bg-[#A9B4C2] rounded-3xl p-5 animated-item shadow-md" style="animation-delay: 0.4s; animation: slideUp 0.5s ease-out 0.4s forwards;">
                <label class="block text-xl font-bold mb-2 text-gray-800">Username</label>
                <input name="username" type="text" value="<%= user.username %>" class="w-full p-3 rounded-xl outline-none border-none focus:ring-4 focus:ring-blue-400 transition-shadow duration-200 text-gray-900 font-medium" required minlength="3" />
            </div>

            <div class="bg-[#A9B4C2] rounded-3xl p-5 animated-item shadow-md" style="animation-delay: 0.5s; animation: slideUp 0.5s ease-out 0.5s forwards;">
                <label class="block text-xl font-bold mb-2 text-gray-800">Email</label>
                <input name="email" type="email" value="<%= user.email %>" class="w-full p-3 rounded-xl outline-none border-none focus:ring-4 focus:ring-blue-400 transition-shadow duration-200 text-gray-900 font-medium" required />
            </div>

            <div class="bg-[#A9B4C2] rounded-3xl p-5 animated-item shadow-md" style="animation-delay: 0.6s; animation: slideUp 0.5s ease-out 0.6s forwards;">
                <label class="block text-xl font-bold mb-2 text-gray-800">Bio</label>
                <textarea name="bio" rows="4" placeholder="Tell us about yourself..." class="w-full p-3 rounded-xl outline-none border-none focus:ring-4 focus:ring-blue-400 transition-shadow duration-200 resize-none text-gray-900 font-medium"><%= user.bio || '' %></textarea>
            </div>

            <div class="bg-[#A9B4C2] rounded-3xl p-5 animated-item shadow-md" style="animation-delay: 0.7s; animation: slideUp 0.5s ease-out 0.7s forwards;">
                <label class="block text-xl font-bold mb-2 text-gray-800">New Password</label>
                <input name="password" type="password" placeholder="Leave blank to keep current password" class="w-full p-3 rounded-xl outline-none border-none focus:ring-4 focus:ring-blue-400 transition-shadow duration-200 text-gray-900 font-medium" minlength="6" />
            </div>

            <div class="bg-[#A9B4C2] rounded-3xl p-5 animated-item shadow-md" style="animation-delay: 0.8s; animation: slideUp 0.5s ease-out 0.8s forwards;">
                <label class="block text-xl font-bold mb-2 text-gray-800">Confirm Password</label>
                <input name="confirm_password" type="password" placeholder="Repeat new password" class="w-full p-3 rounded-xl outline-none border-none focus:ring-4 focus:ring-blue-400 transition-shadow duration-200 text-gray-900 font-medium" minlength="6" />
            </div>

            <div class="flex items-center justify-between pt-4 animated-item" style="animation-delay: 0.8s; animation: slideUp 0.5s ease-out 0.8s forwards;">
                <button type="submit" class="bg-blue-600 text-white font-bold py-3 px-8 rounded-full hover:bg-blue-800 hover:scale-105 transform transition-all duration-300 shadow-lg">
                    Save Changes
                </button>
                <a href="/profile" class="text-lg text-gray-200 hover:text-white underline font-medium transition-all duration-200">
                    Cancel
                </a>
            </div>
        </form>

    </div>

    <script>
        // Real-time profile image preview
        document.getElementById('profileImage').addEventListener('change', function (e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (event) {
                    document.getElementById('profilePreview').src = event.target.result;
                }
                reader.readAsDataURL(file);
            }
        });
    </script>
</body>
</html>