<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign Up | ChatApp</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      @keyframes fadeIn {
        from {
          opacity: 0;
          transform: translateY(10px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      .animate-fadeIn {
        animation: fadeIn 1s ease forwards;
      }

      @keyframes backgroundShift {
        0% {
          background-position: 0% 50%;
        }
        50% {
          background-position: 100% 50%;
        }
        100% {
          background-position: 0% 50%;
        }
      }
      .bg-animated {
        background: linear-gradient(270deg, #5E6572, #7D98A1, #A9B4C2);
        background-size: 600% 600%;
        animation: backgroundShift 15s ease infinite;
      }
    </style>
  </head>

  <body class="bg-animated flex justify-center items-center min-h-screen m-0 font-sans">
    <form
      action="/signup"
      method="POST"
      class="animate-fadeIn bg-[#7D98A1] w-[90%] sm:w-[60%] md:w-[40%] lg:w-[30%] rounded-3xl p-8 flex flex-col justify-center items-center shadow-xl"
    >
      <h1 class="text-3xl font-bold text-center mb-6 text-white">
        Create Account
      </h1>

      <% if (error) { %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-2 rounded-lg w-full mb-4 text-center font-semibold shadow-sm">
            <%= error %>
        </div>
      <% } %>

      <input
        class="bg-[#A9B4C2] hover:bg-[#D9D9D9] text-gray-900 placeholder-gray-600 transition duration-300 ease-in-out text-center font-semibold rounded-3xl w-full h-12 mb-4 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:shadow-lg"
        type="text"
        id="username"
        name="username"
        placeholder="Username"
        required
        minlength="3"
      />

      <input
        class="bg-[#A9B4C2] hover:bg-[#D9D9D9] text-gray-900 placeholder-gray-600 transition duration-300 ease-in-out text-center font-semibold rounded-3xl w-full h-12 mb-4 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:shadow-lg"
        type="email"
        id="email"
        name="email"
        placeholder="Email"
        required
      />

      <input
        class="bg-[#A9B4C2] hover:bg-[#D9D9D9] text-gray-900 placeholder-gray-600 transition duration-300 ease-in-out text-center font-semibold rounded-3xl w-full h-12 mb-6 focus:outline-none focus:ring-2 focus:ring-blue-400 focus:shadow-lg"
        type="password"
        id="password"
        name="password"
        placeholder="Password"
        required
        minlength="6"
      />

      <button
        class="bg-blue-600 transform transition duration-300 ease-in-out text-white font-bold rounded-3xl w-full h-12 mt-2 shadow-md hover:scale-105 hover:bg-blue-800"
        type="submit"
      >
        Sign Up
      </button>

      <p class="text-center mt-6 text-white">
        Already have an account?
        <a
          href="/login"
          class="font-bold text-gray-200 hover:text-white underline transition duration-300"
          >Log in here</a
        >
      </p>
    </form>
  </body>
</html>